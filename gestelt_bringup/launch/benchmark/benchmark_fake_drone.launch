<launch>
  <arg name="num_drones" default="12"/>
  <!-- size of map, change the size inflate x, y, z according to your application -->
  <arg name="map_size_x" default="80.0"/>
  <arg name="map_size_y" default="80.0"/>
  <arg name="map_size_z" default="5.0"/>
  <arg name="map_filepath_rel" default="benchmark_80_20.pcd" />
  <arg name="map_filepath_abs" default="$(find gestelt_bringup)/simulation/fake_map_worlds/$(arg map_filepath_rel)" />
  <!-- Input/output topics -->
  <!-- <param name="/use_sim_time" value="true" /> -->
  <arg name="rviz_config" default="default"/>

  <!-- Add static transform from world to map -->
  <node pkg="tf" type="static_transform_publisher" 
    name="world_to_map_tf" 
    args="0 0 0 0 0 0 1 world map 100">
  </node>

  <!-- RVIZ -->
  <node name="rviz" pkg="rviz" type="rviz" required="true" 
    args="-d $(find gestelt_bringup)/launch/rviz/$(arg rviz_config).rviz"/>

  <!-- swarm topic transmitter bridge-->
  <include file="$(find swarm_bridge)/launch/bridge_udp.launch">
    <arg name="drone_id" value="999"/>
    <arg name="broadcast_ip" value="127.0.0.255"/>
  </include>

  <!-- Global map publisher -->
  <node pkg="fake_map" type="fake_map_publisher" name="fake_map_publisher" output="screen">
      <param name="map/path" value="$(arg map_filepath_abs)"/>
  </node>

  <!-- Drone 0 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="0"/>
    <arg name="init_x"     value="0.5"/>
    <arg name="init_y"     value="0.5"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 1 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="1"/>
    <arg name="init_x"     value="0.5"/>
    <arg name="init_y"     value="-0.5"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 2 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="2"/>
    <arg name="init_x"     value="-0.5"/>
    <arg name="init_y"     value="-0.5"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 3 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="3"/>
    <arg name="init_x"     value="-0.5"/>
    <arg name="init_y"     value="0.5"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 4 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="4"/>
    <arg name="init_x"     value="0.0"/>
    <arg name="init_y"     value="1.0"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 5 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="5"/>
    <arg name="init_x"     value="1.0"/>
    <arg name="init_y"     value="0.0"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 6 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="6"/>
    <arg name="init_x"     value="0.0"/>
    <arg name="init_y"     value="-1.0"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 7 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="7"/>
    <arg name="init_x"     value="-1.0"/>
    <arg name="init_y"     value="0.0"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 8 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="8"/>
    <arg name="init_x"     value="1.0"/>
    <arg name="init_y"     value="1.0"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 9 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="9"/>
    <arg name="init_x"     value="1.0"/>
    <arg name="init_y"     value="-1.0"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 10 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="10"/>
    <arg name="init_x"     value="-1.0"/>
    <arg name="init_y"     value="-1.0"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>

  <!-- Drone 11 -->
  <include file="$(find gestelt_bringup)/launch/fake_drone/fake_drone_single.xml">
    <arg name="drone_id"   value="11"/>
    <arg name="init_x"     value="-1.0"/>
    <arg name="init_y"     value="1.0"/>
    <arg name="init_z"     value="0.5"/>
    <arg name="map_filepath" value="$(arg map_filepath_abs)"/>
    <arg name="num_drones" value="$(arg num_drones)"/>
    <arg name="map_size_x" value="$(arg map_size_x)"/>
    <arg name="map_size_y" value="$(arg map_size_y)"/>
    <arg name="map_size_z" value="$(arg map_size_z)"/>
  </include>


</launch>
